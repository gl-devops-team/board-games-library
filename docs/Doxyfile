# Project information
PROJECT_NAME           = "Board Game Borrowing Website"
PROJECT_BRIEF          = "A web application for borrowing and managing board games"
PROJECT_NUMBER         = 1.0

# Paths
OUTPUT_DIRECTORY       = .
INPUT                  = ../app
RECURSIVE              = YES

# File types
FILE_PATTERNS          = *.py \
                         *.js \
                         *.jsx

# Extract documentation
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html

# Disable LaTeX
GENERATE_LATEX         = NO

# Diagrams
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES

# Optimization
OPTIMIZE_OUTPUT_JAVA   = YES
OPTIMIZE_OUTPUT_FOR_C  = NO

# Markdown support
MARKDOWN_SUPPORT       = YES

# Warnings
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = YES
WARN_LOGFILE           = warnings.log